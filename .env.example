# --- Service ---
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173

# --- DB ---
DATABASE_URL=postgresql+psycopg://bio:bio@db:5432/bio

# --- Broker / cache ---
REDIS_URL=redis://redis:6379/0

# --- Object store (MinIO in dev, S3 in prod) ---
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=bio-blobs
S3_ACCESS_KEY=biominio
S3_SECRET_KEY=biominio-secret
S3_USE_SSL=false

# --- Crypto / KMS ---
# local backend uses MASTER_KEY for envelope encryption (dev only)
# in prod set KMS_BACKEND=aws and use AWS_KMS_KEY_ID
KMS_BACKEND=local
MASTER_KEY=ZGV2LW9ubHktbWFzdGVyLWtleS1jaGFuZ2UtbWUtMzItYnl0ZXM=
AWS_KMS_KEY_ID=

# Ed25519 signing key for receipts (base64 32 bytes). Auto-generated on first boot if blank.
RECEIPT_SIGNING_KEY=

# --- Auth ---
JWT_SECRET=dev-jwt-secret-change-me
JWT_ALG=HS256
JWT_EXPIRE_MINUTES=60

# --- Verification policy ---
MATCH_THRESHOLD=0.68
LIVENESS_MIN_SCORE=0.85
APPROVE_SIMILARITY_MIN=0.40
REVIEW_SIMILARITY_MIN=0.32
BLOB_RETENTION_DAYS=30
RATE_LIMIT_PER_MIN=5
MAX_ID_BYTES=8388608
MAX_VIDEO_BYTES=26214400

# --- Models ---
ANTI_SPOOF_MODEL_PATH=models/anti_spoof_mn3.onnx
FACE_MODEL_NAME=ArcFace
FACE_DETECTOR=retinaface
