# --- Service ---
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173

# --- DB ---
DATABASE_URL=postgresql+psycopg://bio:bio@db:5432/bio

# --- Broker / cache ---
REDIS_URL=redis://redis:6379/0

# --- Object store (MinIO in dev, S3 in prod) ---
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=bio-blobs
S3_ACCESS_KEY=biominio
S3_SECRET_KEY=biominio-secret
S3_USE_SSL=false

# --- Crypto / KMS ---
# local backend uses MASTER_KEY for envelope encryption (DEV ONLY).
# In prod set KMS_BACKEND=aws and use AWS_KMS_KEY_ID.
# Run `make seed` to fill MASTER_KEY/RECEIPT_SIGNING_KEY/JWT_SECRET with fresh
# random values. Boot will fail in production if these stay blank.
KMS_BACKEND=local
MASTER_KEY=
AWS_KMS_KEY_ID=

# Ed25519 signing key for receipts (base64 32 bytes). REQUIRED in production.
# In dev `make seed` generates one for you. Boot fails in prod if blank.
RECEIPT_SIGNING_KEY=

# --- Auth ---
# Required in production. Min 32 chars of random entropy.
# Boot fails if left blank or set to a known-default placeholder in production.
JWT_SECRET=
JWT_ALG=HS256
JWT_EXPIRE_MINUTES=60
# Issuer / audience this service expects on inbound tokens. Tokens missing
# either claim or carrying the wrong values are rejected.
JWT_ISSUER=biometrical
JWT_AUDIENCE=biometrical-verify

# --- Verification policy ---
MATCH_THRESHOLD=0.68
LIVENESS_MIN_SCORE=0.85
# Aligned with ArcFace / LFW-recommended cosine distance ≤ 0.32 (similarity ≥ 0.68).
# The previous 0.40 floor approved matches considered weak by the model authors.
APPROVE_SIMILARITY_MIN=0.55
REVIEW_SIMILARITY_MIN=0.40
BLOB_RETENTION_DAYS=30
RATE_LIMIT_PER_MIN=5
MAX_ID_BYTES=8388608
MAX_VIDEO_BYTES=26214400

# --- Models ---
ANTI_SPOOF_MODEL_PATH=models/anti_spoof_mn3.onnx
# SHA-256 of the expected model file. Bootstrap refuses to install a download
# whose hash does not match. Set blank to skip the check (dev only).
ANTI_SPOOF_MODEL_SHA256=
FACE_MODEL_NAME=ArcFace
FACE_DETECTOR=retinaface
